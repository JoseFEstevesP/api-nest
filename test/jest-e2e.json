{
	"moduleFileExtensions": ["js", "json", "ts"],
	"rootDir": ".",
	"testEnvironment": "node",
	"testRegex": ".e2e-spec.ts$",
	"transform": {
		"^.+\\.(t|j)s$": [
			"ts-jest",
			{
				"tsconfig": "tsconfig.json",
				"isolatedModules": true
			}
		]
	},
	"moduleNameMapper": {
		"^@/(.*)$": "<rootDir>/../src/$1"
	}
}
