{
	"name": "api-nest",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24.6.0",
		"pnpm": ">=10.14.0"
	},
	"packageManager": "pnpm@10.32.1",
	"scripts": {
		"build": "nest build",
		"start": "nest start",
		"dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"lint": "oxlint src/ --quiet",
		"lint:fix": "oxlint src/ --fix --quiet",
		"lint:check": "oxlint src/",
		"lintStaged": "lint-staged",
		"migrate:undo:all": "sequelize-cli db:migrate:undo:all",
		"migrate:undo": "sequelize-cli db:migrate:undo",
		"migrate": "sequelize-cli db:migrate",
		"migrate:create": "node scripts/generateESMMigration.js",
		"module:generate": "node scripts/moduleGenerator.js",
		"prepare": "husky",
		"pretest": "pnpm run setup:test-db",
		"test": "vitest run --config vitest.config.ts",
		"test:watch": "vitest",
		"test:cov": "vitest run --config vitest.config.ts --coverage",
		"test:e2e": "jest --config test/jest-e2e.json"
	},
	"dependencies": {
		"@formkit/tempo": "1.0.0",
		"@keyv/redis": "5.1.6",
		"@nestjs/cache-manager": "3.1.0",
		"@nestjs/common": "11.1.16",
		"@nestjs/config": "4.0.3",
		"@nestjs/core": "11.1.16",
		"@nestjs/jwt": "11.0.2",
		"@nestjs/mapped-types": "2.1.0",
		"@nestjs/passport": "11.0.5",
		"@nestjs/platform-express": "11.1.16",
		"@nestjs/schedule": "6.1.1",
		"@nestjs/serve-static": "5.0.4",
		"@nestjs/swagger": "11.2.6",
		"@nestjs/terminus": "11.1.1",
		"@nestjs/throttler": "6.5.0",
		"@types/passport-google-oauth20": "2.0.17",
		"bcrypt": "6.0.0",
		"cache-manager": "7.2.8",
		"class-transformer": "0.5.1",
		"class-validator": "0.15.1",
		"cookie-parser": "1.4.7",
		"dotenv": "17.3.1",
		"express": "5.2.1",
		"helmet": "8.1.0",
		"keyv": "5.6.0",
		"multer": "2.1.1",
		"nodemailer": "8.0.2",
		"passport-google-oauth20": "2.0.0",
		"passport-jwt": "4.0.1",
		"pg": "8.20.0",
		"pg-hstore": "2.3.4",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.2",
		"sequelize": "6.37.8",
		"sequelize-typescript": "2.1.6",
		"winston": "3.19.0",
		"winston-daily-rotate-file": "5.0.0"
	},
	"devDependencies": {
		"@commitlint/cli": "20.4.3",
		"@commitlint/config-conventional": "20.4.3",
		"@nestjs/cli": "11.0.16",
		"@nestjs/schematics": "11.0.9",
		"@nestjs/sequelize": "11.0.1",
		"@nestjs/testing": "11.1.16",
		"@swc/cli": "0.8.0",
		"@swc/core": "1.15.18",
		"@types/bcrypt": "6.0.0",
		"@types/cookie-parser": "1.4.10",
		"@types/express": "5.0.6",
		"@types/multer": "2.1.0",
		"@types/node": "25.4.0",
		"@types/nodemailer": "7.0.11",
		"@types/passport-jwt": "4.0.1",
		"@types/supertest": "7.2.0",
		"husky": "9.1.7",
		"lint-staged": "16.3.3",
		"oxlint": "1.52.0",
		"prettier": "3.8.1",
		"sequelize-cli": "6.6.5",
		"tsconfig-paths": "4.2.0",
		"typescript": "5.9.3",
		"vitest": "4.0.18"
	},
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged"
		}
	},
	"lint-staged": {
		"**/*.{ts,js}": [
			"pnpm format",
			"pnpm lint:check"
		]
	},
	"pnpm": {
		"overrides": {
			"@nestjs/core": "11.1.16"
		},
		"onlyBuiltDependencies": [
			"@nestjs/core",
			"@scarf/scarf",
			"@swc/core",
			"bcrypt",
			"esbuild",
			"sharp",
			"unrs-resolver"
		]
	}
}
