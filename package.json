{
	"name": "api-nest",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "MIT",
	"scripts": {
		"build": "swc src -d dist --config-file=.swcrc --no-swcrc",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "nest start",
		"dev": "pnpm migrate && nest start --watch",
		"start:debug": "node --inspect -r @swc/register -r tsconfig-paths/register src/main.ts",
		"start:prod": "pnpm run build && node dist/main.js",
		"migrate": "sequelize-cli db:migrate",
		"migrate:undo": "sequelize-cli db:migrate:undo",
		"migrate:undo:all": "sequelize-cli db:migrate:undo:all",
		"lint": "oxlint . --fix",
		"prepare": "husky",
		"lintStaged": "lint-staged",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"test:ui": "vitest ui",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@formkit/tempo": "0.1.2",
		"@keyv/redis": "4.4.0",
		"@nestjs/cache-manager": "3.0.1",
		"@nestjs/common": "11.1.3",
		"@nestjs/config": "4.0.2",
		"@nestjs/core": "11.1.3",
		"@nestjs/jwt": "11.0.0",
		"@nestjs/mapped-types": "2.1.0",
		"@nestjs/passport": "11.0.5",
		"@nestjs/platform-express": "11.1.3",
		"@nestjs/schedule": "6.0.0",
		"@nestjs/serve-static": "5.0.3",
		"@nestjs/swagger": "11.2.0",
		"@nestjs/throttler": "6.4.0",
		"bcrypt": "6.0.0",
		"cache-manager": "7.0.0",
		"class-transformer": "0.5.1",
		"class-validator": "0.14.2",
		"cookie-parser": "1.4.7",
		"dotenv": "16.5.0",
		"intl-dateformat": "0.1.4",
		"keyv": "5.3.4",
		"multer": "2.0.1",
		"nodemailer": "7.0.3",
		"passport-jwt": "4.0.1",
		"pg": "8.16.0",
		"pg-hstore": "2.3.4",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.2",
		"sequelize": "6.37.7",
		"sequelize-typescript": "2.1.6",
		"sharp": "0.34.2",
		"winston": "3.17.0",
		"winston-daily-rotate-file": "5.0.0"
	},
	"devDependencies": {
		"@commitlint/cli": "19.8.1",
		"@commitlint/config-conventional": "19.8.1",
		"@nestjs/cli": "11.0.7",
		"@nestjs/schematics": "11.0.5",
		"@nestjs/sequelize": "11.0.0",
		"@nestjs/testing": "11.1.3",
		"@swc/cli": "^0.7.8",
		"@swc/core": "^1.12.11",
		"@swc/register": "^0.1.10",
		"@types/bcrypt": "5.0.2",
		"@types/cookie-parser": "1.4.9",
		"@types/express": "5.0.3",
		"@types/multer": "1.4.13",
		"@types/node": "24.0.0",
		"@types/nodemailer": "6.4.17",
		"@types/passport-jwt": "4.0.1",
		"@types/sequelize": "4.28.20",
		"@types/supertest": "6.0.3",
		"@vitest/coverage-v8": "^3.2.4",
		"@vitest/ui": "^3.2.4",
		"happy-dom": "^18.0.1",
		"husky": "9.1.7",
		"lint-staged": "16.1.0",
		"oxlint": "1.0.0",
		"prettier": "3.5.3",
		"sequelize-cli": "6.6.3",
		"sequelize-mock": "0.10.2",
		"source-map-support": "0.5.21",
		"supertest": "7.1.1",
		"ts-loader": "9.5.2",
		"ts-node": "10.9.2",
		"tsconfig-paths": "4.2.0",
		"typescript": "5.8.3",
		"vitest": "^3.2.4"
	}
}
