{
	"name": "api-nest",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24.4.1",
		"pnpm": ">=10.13.1"
	},
	"packageManager": "pnpm@10.14.0",
	"scripts": {
		"build": "swc src -d dist --config-file=.swcrc --no-swcrc",
		"dev": "pnpm migrate && nest start --watch",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"lint": "oxlint . --fix",
		"lintStaged": "lint-staged",
		"migrate:undo:all": "sequelize-cli db:migrate:undo:all",
		"migrate:undo": "sequelize-cli db:migrate:undo",
		"migrate": "sequelize-cli db:migrate",
		"prepare": "husky",
		"start:debug": "node --inspect -r @swc/register -r tsconfig-paths/register src/main.ts",
		"start:prod": "node dist/main --generate-docs && node dist/main",
		"start": "nest start",
		"test:cov:ui": "vitest --coverage --ui --config vitest.unit.config.ts",
		"test:cov": "vitest run --coverage --config vitest.unit.config.ts",
		"test:debug": "vitest --config vitest.unit.config.ts --inspect-brk --no-file-parallelism",
		"test:e2e:run": "vitest run --config vitest.e2e.config.ts",
		"test:e2e:watch": "vitest --config vitest.e2e.config.ts --watch",
		"test:e2e:ui": "vitest --config vitest.e2e.config.ts --ui",
		"test:e2e": "vitest --config vitest.e2e.config.ts",
		"test:unit:run": "vitest run --config vitest.unit.config.ts",
		"test:unit:watch": "vitest --config vitest.unit.config.ts --watch",
		"test:unit:ui": "vitest --config vitest.unit.config.ts --ui",
		"test:unit": "vitest --config vitest.unit.config.ts"
	},
	"dependencies": {
		"@formkit/tempo": "0.1.2",
		"@keyv/redis": "5.0.0",
		"@nestjs/cache-manager": "3.0.1",
		"@nestjs/common": "11.1.5",
		"@nestjs/config": "4.0.2",
		"@nestjs/core": "11.1.5",
		"@nestjs/jwt": "11.0.0",
		"@nestjs/mapped-types": "2.1.0",
		"@nestjs/passport": "11.0.5",
		"@nestjs/platform-express": "11.1.5",
		"@nestjs/schedule": "6.0.0",
		"@nestjs/serve-static": "5.0.3",
		"@nestjs/swagger": "11.2.0",
		"@nestjs/throttler": "6.4.0",
		"bcrypt": "6.0.0",
		"class-transformer": "0.5.1",
		"class-validator": "0.14.2",
		"cookie-parser": "1.4.7",
		"dotenv": "17.2.1",
		"express": "5.1.0",
		"intl-dateformat": "0.1.4",
		"keyv": "5.4.0",
		"multer": "2.0.2",
		"nodemailer": "7.0.5",
		"passport-jwt": "4.0.1",
		"pg": "8.16.3",
		"pg-hstore": "2.3.4",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.2",
		"sequelize": "6.37.7",
		"sequelize-typescript": "2.1.6",
		"sharp": "0.34.3",
		"winston": "3.17.0",
		"winston-daily-rotate-file": "5.0.0"
	},
	"devDependencies": {
		"@commitlint/cli": "19.8.1",
		"@commitlint/config-conventional": "19.8.1",
		"@nestjs/cli": "11.0.10",
		"@nestjs/schematics": "11.0.7",
		"@nestjs/sequelize": "11.0.0",
		"@nestjs/testing": "11.1.5",
		"@swc/cli": "0.7.8",
		"@swc/core": "1.13.3",
		"@types/bcrypt": "6.0.0",
		"@types/cookie-parser": "1.4.9",
		"@types/express": "5.0.3",
		"@types/multer": "2.0.0",
		"@types/node": "24.1.0",
		"@types/nodemailer": "6.4.17",
		"@types/passport-jwt": "4.0.1",
		"@types/supertest": "6.0.3",
		"@vitest/coverage-istanbul": "^3.2.4",
		"@vitest/coverage-v8": "3.2.4",
		"@vitest/ui": "3.2.4",
		"cache-manager": "7.1.0",
		"cross-env": "^10.0.0",
		"husky": "9.1.7",
		"lint-staged": "16.1.2",
		"oxlint": "1.9.0",
		"prettier": "3.6.2",
		"sequelize-cli": "6.6.3",
		"sequelize-mock": "0.10.2",
		"source-map-support": "0.5.21",
		"supertest": "7.1.4",
		"ts-loader": "9.5.2",
		"ts-node": "10.9.2",
		"tsconfig-paths": "4.2.0",
		"typescript": "5.9.2",
		"unplugin-swc": "1.5.5",
		"vite-tsconfig-paths": "5.1.4",
		"vitest": "^3.2.4"
	},
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged",
			"pre-push": "pnpm test"
		}
	},
	"lint-staged": {
		"*.ts": [
			"oxlint --fix",
			"prettier --write"
		]
	},
	"pnpm": {
		"overrides": {
			"@nestjs/core": "11.1.5"
		},
		"onlyBuiltDependencies": [
			"@nestjs/core",
			"@scarf/scarf",
			"@swc/core",
			"bcrypt",
			"esbuild",
			"sharp",
			"unrs-resolver"
		]
	}
}
